# Copy this file to .env and fill in the values. fetch.py / upload.py load .env
# automatically (python-dotenv). On a server, set these as real env vars instead.

# Hugging Face dataset repo that holds the tables (one folder per table).
HORIZON_HF_REPO=Marine65/lsdi-horizon-data

# Hugging Face access token (https://huggingface.co/settings/tokens).
#   - upload.py  -> required, must be a WRITE token
#   - fetch.py   -> only needed for a private repo or higher rate limits (READ is enough)
HF_TOKEN=
